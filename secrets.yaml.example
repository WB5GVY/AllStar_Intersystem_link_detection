# AllStar Link Detector — Secrets Configuration
#
# Copy this file to: ~/.config/asl_link_detector/secrets.yaml
# Then set permissions: chmod 600 ~/.config/asl_link_detector/secrets.yaml
#
# These credentials are loaded at runtime and merged into the main config.
# NEVER commit this file to version control.

email:
  username: "your_email@gmail.com"       # Gmail address (or other SMTP provider)
  password: "your_app_password"          # Gmail App Password (not your regular password)
  from_addr: "your_email@gmail.com"      # "From" address on outgoing emails
  recipients:
    - "operator1@example.com"            # Who receives alert emails
    - "operator2@example.com"

qrz:
  username: "YOUR_CALLSIGN"             # QRZ.com username (your callsign)
  password: "your_qrz_password"         # QRZ.com password (requires XML subscription)
